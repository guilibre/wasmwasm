param cf = 1000
param q = 1

static sr_inv = 1/SAMPLE_RATE
w0 = 2*PI*cf*sr_inv
c = cos(w0)
s = sin(w0)
alpha = s/(2*q)

a0_inv = 1/(1 + alpha)
a1 = -a0_inv*2*c
a2 = a0_inv*(1 - alpha)
b0 = a0_inv*alpha
b1 = 0
b2 = -a0_inv*alpha

static z1 = 0
static z2 = 0

y = b0*IN[0] + z1
z1 = b1*IN[0] - a1*y + z2
z2 = b2*IN[0] - a2*y

OUT[0] <- y
