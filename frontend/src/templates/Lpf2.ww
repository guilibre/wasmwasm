param cutoff_lo = 0
param Q = 1

w0 = 2*PI*cutoff_lo/SAMPLE_RATE
c = cos(w0)
s = sin(w0)
alpha = s/(2*Q)

a0_inv = 1/(1 + alpha)
a1 = -a0_inv*2*c
a2 = a0_inv*(1 - alpha)
b0 = a0_inv*(1 - c)/2
b1 = a0_inv*(1 - c)
b2 = a0_inv*(1 - c)/2

static z1 = 0
static z2 = 0

y = b0*IN[0] + z1
z1 = b1*IN[0] - a1*y + z2
z2 = b2*IN[0] - a2*y

OUT[0] <- y
