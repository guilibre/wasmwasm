param gate = 0
param amp = 0.2
param atk = 0.01
param dec = 0.1
param sus = 0.8
param rel = 0.5

static gate_ = 0
static env = 0
static denv = 0

OUT[0] <- amp*env

gate > gate_ ? denv = 1/(atk*SAMPLE_RATE)
env = min 1 (max 0 (env + denv))
gate ? (
    env < 1 ? (
        denv < 0 ? (env <= sus ? denv = 0)
    ) : denv = 1/((sus - 1)*dec*SAMPLE_RATE)
) : (
    env > 0 ? denv = -1/(rel*SAMPLE_RATE) : die
)

gate_ = gate
