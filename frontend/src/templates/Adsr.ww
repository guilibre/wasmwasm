param gate = 0
param atk = 0.01
param dec = 0.1
param sus = 0.8
param rel = 1

static t = 0
static dt = 1/SAMPLE_RATE
static gate_ = 0
static env = 0

OUT[0] <- IN[0] * env

denv = gate ? (t < atk ? 1/(atk*SAMPLE_RATE) : (env > sus & t < atk + dec ? -1/(dec*SAMPLE_RATE) : 0)) : -1/(rel*SAMPLE_RATE)
env = min 1 (max 0 (env + denv))

t = gate > gate_ ? 0 : t + dt
gate_ = gate
