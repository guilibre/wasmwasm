param echo_delay_l = 0.1
param echo_delay_r = 0.1
param decay_l = 0.8
param decay_r = 0.8

buffer_l = delay 4800 {_. 0}
buffer_r = delay 4800 {_. 0}
static idx_l = 0
static idx_r = 0

out_l = IN[0] - decay_l*@[idx_l]buffer_l
out_r = IN[1] - decay_r*@[idx_r]buffer_r
OUT[0] <- out_l
OUT[1] <- out_r

@[idx_l]buffer_l = out_l
@[idx_r]buffer_r = out_r
idx_l = idx_l + 1
idx_r = idx_r + 1
idx_l >= echo_delay_l*SAMPLE_RATE ? idx_l = 0
idx_r >= echo_delay_r*SAMPLE_RATE ? idx_r = 0
