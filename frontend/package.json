{
    "name": "wasmwasm",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "deploy": "gh-pages -d dist",
        "lint": "eslint .",
        "predeploy": "npm run build",
        "preview": "vite preview",
